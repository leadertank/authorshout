<section class="content-page">
  <article class="panel content-page-hero">
    <h1><%= @form.title %></h1>
    <% if @form.description.present? %>
      <p class="content-page-summary"><%= @form.description %></p>
    <% end %>
  </article>

  <% if @form.requires_payment? %>
    <article class="panel form-public-payment-panel">
      <h2>Payment Required</h2>
      <p>
        <strong><%= @form.payment_mode_label %></strong>
        for <%= @form.formatted_amount %>
        <% if @form.subscription? %>
          every <%= @form.billing_interval %>
        <% end %>
      </p>
      <p class="cms-field-hint">Your answers are saved before checkout so you can track paid, pending, and canceled entries.</p>

      <% unless @checkout_readiness.ready? %>
        <div class="form-public-warning">
          <strong>Payment temporarily unavailable</strong>
          <p class="cms-field-hint"><%= @checkout_readiness.messages.join(" ") %></p>
        </div>
      <% end %>
    </article>
  <% end %>

  <% if @form_errors.present? %>
    <div class="form-errors">
      <h2>Please fix these issues:</h2>
      <ul>
        <% @form_errors.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% values = @submission&.payload || {} %>
  <%= form_with url: submit_form_path(@form), method: :post, class: "panel form-public-shell" do %>
    <div class="form-public-grid">
      <% @form.form_fields.each do |field| %>
        <%= render "field_input", field: field, values: values %>
      <% end %>
    </div>

    <div class="cms-form-actions">
      <%= submit_tag @form.submit_button_text, class: "button", disabled: (@form.requires_payment? && !@checkout_readiness.ready?) %>
    </div>
  <% end %>
</section>