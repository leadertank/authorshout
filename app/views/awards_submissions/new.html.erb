<section class="panel auth-shell awards-form-shell">
  <h1>8th Annual Author Shout Book Awards Submission Form</h1>

  <p><strong>$20 PER BOOK</strong></p>
  <p>Author Shout Book Awards.</p>
  <p>Entry Fee: $20 per book</p>
  <p><strong>*NOTE*</strong> Enter as many books as you like.</p>
  <p>Fill out the form below then click pay and submit to enter your book.</p>

  <% if @awards_submission.errors.any? %>
    <div class="form-errors">
      <h2>Please fix these issues:</h2>
      <ul>
        <% @awards_submission.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: @awards_submission, url: awards_submissions_path, class: "form-stack", data: { turbo: false } do |f| %>
    <div>
      <%= f.label :first_name, "First Name" %>
      <%= f.text_field :first_name, autocomplete: "given-name", required: true %>
    </div>

    <div>
      <%= f.label :last_name, "Last Name" %>
      <%= f.text_field :last_name, autocomplete: "family-name", required: true %>
    </div>

    <div>
      <%= f.label :author_email, "Author's E-Mail Address (For contact purposes only)" %>
      <%= f.email_field :author_email, autocomplete: "email", required: true %>
    </div>

    <div>
      <%= f.label :book_title, "What is the title of the book you would like to enter?" %>
      <%= f.text_field :book_title, required: true %>
    </div>

    <div>
      <%= f.label :book_url, "Where can we find your book? (Link/URL)" %>
      <%= f.url_field :book_url, placeholder: "https://", required: true %>
    </div>

    <div>
      <%= f.label :website_url, "Do you have a website? (Link/URL)" %>
      <%= f.url_field :website_url, placeholder: "https://" %>
    </div>

    <div>
      <%= f.label :x_url, "What is the Link/URL to your X.com (Twitter)?" %>
      <%= f.url_field :x_url, placeholder: "https://x.com/..." %>
    </div>

    <div>
      <%= f.label :facebook_url, "What is the Link/URL to your Facebook?" %>
      <%= f.url_field :facebook_url, placeholder: "https://facebook.com/..." %>
    </div>

    <div>
      <%= f.label :instagram_url, "What is the Link/URL to your Instagram?" %>
      <%= f.url_field :instagram_url, placeholder: "https://instagram.com/..." %>
    </div>

    <div>
      <%= f.submit "Submit Payment and Enter Your Book", class: "button awards-submit-button" %>
    </div>
  <% end %>
</section>
