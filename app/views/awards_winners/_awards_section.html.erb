<section class="books-feed" id="<%= dom_id %>">
  <div class="section-header section-header-split">
    <div>
      <h2><%= heading %></h2>
      <p><%= description %></p>
    </div>

    <div class="section-header-controls">
      <div class="section-header-actions">
        <div class="books-pager books-pager-inline">
          <% if page > 1 %>
            <%= link_to "Previous", awards_winners_path(previous_params), class: "pager-button" %>
          <% else %>
            <span class="pager-button disabled">Previous</span>
          <% end %>

          <% if page < total_pages %>
            <%= link_to "Next", awards_winners_path(next_params), class: "pager-button" %>
          <% else %>
            <span class="pager-button disabled">Next</span>
          <% end %>
        </div>

        <%= link_to "View All", view_all_path, class: "button button-outline" %>
      </div>

      <p class="pager-status pager-status-inline">Page <%= page %> of <%= total_pages %></p>
    </div>
  </div>

  <% if books.any? %>
    <div class="book-grid">
      <% books.each do |manual_award| %>
        <%= render "shared/manual_award_book_card", manual_award: manual_award %>
      <% end %>
    </div>
  <% else %>
    <p class="empty-state">No books are currently set for this section.</p>
  <% end %>
</section>
