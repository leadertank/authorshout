<div class="home-share-wrap">
  <p class="home-share-lead">Share this page on social (Click a button below).</p>
  <div class="header-share-row">
    <%= render "shared/share_buttons",
               url: root_url,
               text: "Discover member-submitted books on AuthorShout" %>
  </div>
</div>

<% if @featured_books.any? %>
  <section class="panel featured-books-panel" data-controller="featured-carousel">
    <div class="section-header">
      <h2>Featured Books</h2>
    </div>

    <div class="featured-carousel-shell">
      <button type="button" class="featured-carousel-nav" data-featured-carousel-target="prev" data-action="click->featured-carousel#prev" aria-label="Previous featured book">&#10094;</button>

      <div class="featured-carousel-viewport">
        <div class="featured-carousel-track" data-featured-carousel-target="track">
          <% @featured_books.each_slice(4) do |books_group| %>
            <section class="featured-carousel-slide" data-featured-carousel-target="slide">
              <div class="featured-grid">
                <% books_group.each do |book| %>
                  <article class="book-card featured-book-card">
                    <%= link_to book.purchase_url, target: "_blank", rel: "noopener", class: "featured-cover-link" do %>
                      <% if book.cover_image_source.present? %>
                        <%= image_tag book.cover_image_source, alt: "#{book.title} cover", class: "featured-cover-image" %>
                      <% else %>
                        <div class="featured-cover-image fallback-cover">No cover uploaded</div>
                      <% end %>
                    <% end %>

                    <span class="book-featured-badge">&#9733; Featured</span>
                    <h3 class="book-card-title"><%= book.title %></h3>
                    <p class="meta-line book-card-author">
                      by <%= author_name_with_verified_badge(book.user, profile: book.profile, linked: true) %>
                    </p>
                    <div class="book-actions">
                      <%= render "shared/book_like_button", book: book %>
                    </div>
                  </article>
                <% end %>
              </div>
            </section>
          <% end %>
        </div>
      </div>

      <button type="button" class="featured-carousel-nav" data-featured-carousel-target="next" data-action="click->featured-carousel#next" aria-label="Next featured book">&#10095;</button>
    </div>
  </section>
<% end %>

<section class="books-feed">
  <div class="section-header">
    <h2>Latest Member Book Covers</h2>
    <p>Latest submissions from the full member community.</p>
  </div>

  <div class="books-pager">
    <% if @page > 1 %>
      <%= link_to "Previous", root_path(page: @page - 1), class: "pager-button" %>
    <% else %>
      <span class="pager-button disabled">Previous</span>
    <% end %>

    <% if @page < @total_pages %>
      <%= link_to "Next", root_path(page: @page + 1), class: "pager-button" %>
    <% else %>
      <span class="pager-button disabled">Next</span>
    <% end %>
  </div>
  <p class="pager-status">Page <%= @page %> of <%= @total_pages %></p>

  <% if @books.any? %>
    <div class="book-grid">
      <% @books.each do |book| %>
        <article class="book-card">
          <%= link_to book.purchase_url, target: "_blank", rel: "noopener", class: "book-cover-link" do %>
            <% if book.cover_image_source.present? %>
              <%= image_tag book.cover_image_source, alt: "#{book.title} cover", class: "book-cover" %>
            <% else %>
              <div class="book-cover fallback-cover">No cover uploaded</div>
            <% end %>
          <% end %>

          <h3 class="book-card-title"><%= book.title %></h3>
          <p class="meta-line book-card-author">
            by
            <%= author_name_with_verified_badge(book.user, profile: book.profile, linked: true) %>
          </p>

          <div class="book-actions">
            <%= render "shared/book_like_button", book: book %>
          </div>
        </article>
      <% end %>
    </div>

    <div class="books-pager books-pager-bottom">
      <% if @page > 1 %>
        <%= link_to "Previous", root_path(page: @page - 1), class: "pager-button" %>
      <% else %>
        <span class="pager-button disabled">Previous</span>
      <% end %>

      <% if @page < @total_pages %>
        <%= link_to "Next", root_path(page: @page + 1), class: "pager-button" %>
      <% else %>
        <span class="pager-button disabled">Next</span>
      <% end %>
    </div>
    <p class="pager-status">Page <%= @page %> of <%= @total_pages %></p>
  <% else %>
    <p class="empty-state">No books have been added yet. Be the first member to add one.</p>
  <% end %>
</section>
