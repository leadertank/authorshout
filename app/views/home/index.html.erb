<div class="home-share-wrap">
  <p class="home-share-lead">Share this page on social (Click a button below).</p>
  <div class="header-share-row">
    <%= render "shared/share_buttons",
               url: root_url,
               text: "Discover member-submitted books on AuthorShout" %>
  </div>
</div>

<section class="home-awards-banner">
  <%= link_to new_awards_submission_path, class: "home-awards-banner-link" do %>
    <%= image_tag "https://authorshout-media.sfo3.cdn.digitaloceanspaces.com/uploads/8th%20Annual%20Author%20Shout%20Awards%20Banner.png",
                  alt: "Author Shout Awards banner",
                  class: "home-awards-banner-image" %>
  <% end %>
</section>

<% if @featured_books.any? %>
  <section class="books-feed" id="featured-books">
    <div class="section-header section-header-split">
      <div>
        <h2>Featured Books</h2>
        <p>Discover the latest featured books highlighted on Author Shout.</p>
      </div>

      <div class="section-header-controls">
        <div class="section-header-actions">
          <div class="books-pager books-pager-inline">
            <% if @featured_page > 1 %>
              <%= link_to "Previous", root_path(featured_page: @featured_page - 1, latest_page: @latest_page, anchor: "featured-books"), class: "pager-button" %>
            <% else %>
              <span class="pager-button disabled">Previous</span>
            <% end %>

            <% if @featured_page < @featured_total_pages %>
              <%= link_to "Next", root_path(featured_page: @featured_page + 1, latest_page: @latest_page, anchor: "featured-books"), class: "pager-button" %>
            <% else %>
              <span class="pager-button disabled">Next</span>
            <% end %>
          </div>

          <%= link_to "View All Featured", featured_books_path, class: "button button-outline" %>
        </div>

        <p class="pager-status pager-status-inline">Page <%= @featured_page %> of <%= @featured_total_pages %></p>
      </div>
    </div>

    <div class="book-grid">
      <% @featured_books.each do |book| %>
        <%= render "shared/public_book_card", book: book, featured_badge: true %>
      <% end %>
    </div>
  </section>
<% end %>

<section class="books-feed" id="latest-book-covers">
  <div class="section-header section-header-split">
    <div>
      <h2>Latest Book Covers</h2>
      <p>Books are listed by submission time. Click a cover to view the shared book link.</p>
    </div>

    <div class="section-header-controls">
      <div class="books-pager books-pager-inline">
        <% if @latest_page > 1 %>
          <%= link_to "Previous", root_path(featured_page: @featured_page, latest_page: @latest_page - 1, anchor: "latest-book-covers"), class: "pager-button" %>
        <% else %>
          <span class="pager-button disabled">Previous</span>
        <% end %>

        <% if @latest_page < @latest_total_pages %>
          <%= link_to "Next", root_path(featured_page: @featured_page, latest_page: @latest_page + 1, anchor: "latest-book-covers"), class: "pager-button" %>
        <% else %>
          <span class="pager-button disabled">Next</span>
        <% end %>
      </div>

      <p class="pager-status pager-status-inline">Page <%= @latest_page %> of <%= @latest_total_pages %></p>
    </div>
  </div>

  <% if @books.any? %>
    <div class="book-grid">
      <% @books.each do |book| %>
        <%= render "shared/public_book_card", book: book, featured_badge: false %>
      <% end %>
    </div>
  <% else %>
    <p class="empty-state">No books have been added yet. Be the first member to add one.</p>
  <% end %>
</section>
