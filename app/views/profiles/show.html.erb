<section class="profile-shell">
  <% share_text = "Check out #{sanitize(@profile.user.display_name)}'s author profile on AuthorShout" %>
  <% website_url = safe_external_url(@profile.website) %>
  <div class="profile-share-wrap">
    <p class="profile-share-lead">Share this page on social (Click a button below).</p>
    <div class="profile-share-row">
      <%= render "shared/share_buttons",
                 url: profile_url(@profile),
                 text: share_text %>
    </div>
  </div>

  <div class="profile-heading">
    <h1><%= @profile.user.display_name %></h1>
    <% if user_signed_in? && current_user == @profile.user %>
      <%= link_to "Edit Profile", edit_my_profile_path, class: "button" %>
    <% end %>
  </div>

  <div class="profile-grid">
    <article class="panel panel-avatar">
      <h2>Profile Picture</h2>
      <% if @profile.avatar_image_source.present? %>
        <%= image_tag @profile.avatar_image_source, alt: "#{@profile.user.display_name} profile picture", class: "avatar-image" %>
      <% else %>
        <div class="avatar-placeholder">No profile image yet</div>
      <% end %>
    </article>

    <article class="panel panel-bio">
      <h2>Bio</h2>
      <p><%= @profile.bio.presence || "This member has not added a bio yet." %></p>
    </article>

    <article class="panel panel-book">
      <h2>Featured Book</h2>
      <% featured_book = @profile.books.find { |book| book.featured } %>
      <% if featured_book.present? %>
        <div class="profile-book">
          <% if featured_book.cover_image_source.present? %>
            <%= image_tag featured_book.cover_image_source, alt: "#{featured_book.title} cover", class: "book-cover profile-featured-cover" %>
          <% end %>
          <h3><%= featured_book.title %></h3>
          <p>
            <%= link_to "Visit Book Link", featured_book.purchase_url, class: "text-link", target: "_blank", rel: "noopener" %>
          </p>
          <div class="book-actions">
            <%= render "shared/book_like_button", book: featured_book %>
          </div>
        </div>
      <% else %>
        <p>No book added yet.</p>
      <% end %>
    </article>

    <% additional_books = @profile.books.where(featured: false) %>
    <% if additional_books.any? %>
      <article class="panel panel-more-books">
        <h2>More Books From Author</h2>
        <div class="books-grid">
          <% additional_books.each do |book| %>
            <div class="book-card">
              <% if book.cover_image_source.present? %>
                <%= image_tag book.cover_image_source, alt: "#{book.title} cover", class: "book-cover book-grid-cover" %>
              <% else %>
                <div class="book-cover-placeholder">No Cover</div>
              <% end %>
              <h3><%= book.title %></h3>
              <p class="book-link">
                <%= link_to "View Book", book.purchase_url, class: "text-link", target: "_blank", rel: "noopener" %>
              </p>
              <div class="book-actions">
                <%= render "shared/book_like_button", book: book %>
              </div>
            </div>
          <% end %>
        </div>
      </article>
    <% end %>

    <article class="panel panel-links">
      <h2>Website & Social Links</h2>
      <% if @profile.website.present? || @profile.social_links.any? %>
        <ul class="link-list">
          <% if website_url.present? %>
            <li>
              <%= link_to "Website",
                          website_url,
                          target: "_blank",
                          rel: "noopener",
                          class: "social-link-pill social-website" %>
            </li>
          <% end %>
          <% @profile.social_links.each do |name, url| %>
            <li>
              <%= link_to name,
                          url,
                          target: "_blank",
                          rel: "noopener",
                          class: "social-link-pill social-#{name.parameterize}" %>
            </li>
          <% end %>
        </ul>
      <% end %>
    </article>
  </div>
</section>
