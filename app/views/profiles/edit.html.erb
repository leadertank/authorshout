<section class="form-shell">
  <h1>Edit Member Profile</h1>
  <p>FREE members can add 1 book. PAID members can add unlimited books.</p>

  <%= form_with model: @profile, url: my_profile_path, class: "form-stack member-profile-form", data: { controller: "additional-books" } do |f| %>
    <% if @profile.errors.any? %>
      <div class="form-errors">
        <h2>Please fix these issues:</h2>
        <ul>
          <% @profile.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="member-profile-layout">
      <div class="member-profile-main">
        <section class="member-form-section panel">
          <div class="member-form-section-head">
            <h2>Author Details</h2>
            <p>Set the public name, portrait, and short bio readers will see first.</p>
          </div>

          <%= f.fields_for :user do |user_fields| %>
            <%= user_fields.hidden_field :id %>

            <div class="cms-grid-two">
              <div>
                <%= user_fields.label :first_name, "First name" %>
                <%= user_fields.text_field :first_name, autocomplete: "given-name" %>
              </div>

              <div>
                <%= user_fields.label :last_name, "Last name" %>
                <%= user_fields.text_field :last_name, autocomplete: "family-name" %>
              </div>
            </div>

            <div>
              <%= user_fields.label :email, "Email address" %>
              <%= user_fields.email_field :email, autocomplete: "email" %>
            </div>

            <div class="cms-grid-two">
              <div>
                <%= user_fields.label :password, "New password" %>
                <%= user_fields.password_field :password, autocomplete: "new-password" %>
                <p class="form-help">Leave blank to keep your current password.</p>
              </div>

              <div>
                <%= user_fields.label :password_confirmation, "Confirm new password" %>
                <%= user_fields.password_field :password_confirmation, autocomplete: "new-password" %>
              </div>
            </div>
          <% end %>

          <div class="member-form-grid">
            <div>
              <%= f.label :avatar, "Upload profile picture" %>
              <%= f.file_field :avatar, accept: "image/*" %>
              <p class="form-help">Square or portrait images crop best across the site.</p>
            </div>

            <div>
              <%= f.label :avatar_url, "Or use image URL" %>
              <%= f.url_field :avatar_url, placeholder: "https://..." %>
              <p class="form-help">Uploaded files take priority over a pasted image URL.</p>
            </div>
          </div>

          <div>
            <%= f.label :bio, "Bio / Description" %>
            <%= f.text_area :bio, rows: 6, maxlength: 1200 %>
            <p class="form-help">Up to 1200 characters. Lead with the clearest reader-facing summary.</p>
          </div>
        </section>

        <section class="member-form-section panel">
          <div class="member-form-section-head">
            <h2>Books From This Author</h2>
            <% if current_user.paid_member? %>
              <p>PAID plan active. Add unlimited books to showcase your full catalog.</p>
            <% else %>
              <p>FREE plan includes 1 book. Upgrade to PAID for unlimited books.</p>
            <% end %>
          </div>

          <% if @book_limit.present? %>
            <p class="form-help">
              Current plan limit: <strong><%= @book_limit %> book</strong>.
              <% if @book_limit_reached %>
                You have reached your limit.
                <%= link_to "Upgrade to PAID", billing_path, class: "text-link" %>
              <% end %>
            </p>
          <% end %>

          <div id="additional-books-container" data-additional-books-target="container">
            <% @profile.books.each_with_index do |book, index| %>
                <%= f.fields_for :books, book do |book_fields| %>
                  <fieldset class="book-entry book-entry-existing">
                    <legend class="book-entry-legend">Book <%= index + 1 %></legend>
                    
                    <div class="book-entry-grid">
                      <div>
                        <%= book_fields.label :title, "Book title" %>
                        <%= book_fields.text_field :title %>
                      </div>

                      <div>
                        <%= book_fields.label :purchase_url, "Book link" %>
                        <%= book_fields.url_field :purchase_url, placeholder: "https://..." %>
                      </div>

                      <div class="member-form-grid">
                        <div>
                          <%= book_fields.label :cover_image, "Upload book cover" %>
                          <%= book_fields.file_field :cover_image, accept: "image/*" %>
                          <% if book.cover_image.attached? %>
                            <p class="form-help">Current cover: <%= link_to "View", book.cover_image, target: "_blank" %></p>
                          <% end %>
                          <!-- TODO Phase 2: Integrate Digital Ocean Spaces for direct uploads -->
                        </div>

                        <div>
                          <%= book_fields.label :cover_image_url, "Or use cover image URL" %>
                          <%= book_fields.url_field :cover_image_url, placeholder: "https://..." %>
                          <p class="form-help">Use a direct image URL whenever possible for reliable rendering.</p>
                        </div>
                      </div>
                    </div>

                    <div class="book-entry-actions">
                      <%= book_fields.hidden_field :id %>
                      <%= book_fields.hidden_field :_destroy, value: false, class: "destroy-field" %>
                      <button type="button" class="button button-danger remove-book-btn" data-action="click->additional-books#removeBook">Remove</button>
                    </div>
                  </fieldset>
                <% end %>
            <% end %>
          </div>

          <% if @book_limit_reached %>
            <div class="book-entry-actions">
              <%= link_to "Upgrade to Add Unlimited Books", billing_path, class: "button" %>
            </div>
          <% else %>
            <button type="button" id="add-book-btn" class="button button-outline" data-additional-books-target="addBtn" data-action="click->additional-books#addBook">+ Add Another Book</button>
          <% end %>
          
          <template id="book-template" data-additional-books-target="template">
            <%= f.fields_for :books, Book.new, child_index: "NEW_RECORD" do |book_fields| %>
              <fieldset class="book-entry book-entry-new">
                <legend class="book-entry-legend">New Book</legend>
                
                <div class="book-entry-grid">
                  <div>
                    <%= book_fields.label :title, "Book title" %>
                    <%= book_fields.text_field :title %>
                  </div>

                  <div>
                    <%= book_fields.label :purchase_url, "Book link" %>
                    <%= book_fields.url_field :purchase_url, placeholder: "https://..." %>
                  </div>

                  <div class="member-form-grid">
                    <div>
                      <%= book_fields.label :cover_image, "Upload book cover" %>
                      <%= book_fields.file_field :cover_image, accept: "image/*" %>
                      <p class="form-help">Portrait covers look best on the home grid and profile page.</p>
                      <!-- TODO Phase 2: Integrate Digital Ocean Spaces for direct uploads -->
                    </div>

                    <div>
                      <%= book_fields.label :cover_image_url, "Or use cover image URL" %>
                      <%= book_fields.url_field :cover_image_url, placeholder: "https://..." %>
                      <p class="form-help">Use a direct image URL whenever possible for reliable rendering.</p>
                    </div>
                  </div>
                </div>

                <div class="book-entry-actions">
                  <%= book_fields.hidden_field :_destroy, value: false, class: "destroy-field" %>
                  <button type="button" class="button button-danger remove-book-btn" data-action="click->additional-books#removeBook">Remove</button>
                </div>
              </fieldset>
            <% end %>
          </template>
        </section>

        <section class="member-form-section panel">
          <div class="member-form-section-head">
            <h2>Website & Social</h2>
            <p>Add the destinations you want readers to visit. Only valid http/https URLs are accepted.</p>
          </div>

          <div>
            <%= f.label :website, "Website" %>
            <%= f.url_field :website, placeholder: "https://..." %>
          </div>

          <div class="cms-grid-two">
            <div>
              <%= f.label :x_url, "X" %>
              <%= f.url_field :x_url, placeholder: "https://x.com/..." %>
            </div>
            <div>
              <%= f.label :facebook_url, "Facebook" %>
              <%= f.url_field :facebook_url, placeholder: "https://facebook.com/..." %>
            </div>
            <div>
              <%= f.label :instagram_url, "Instagram" %>
              <%= f.url_field :instagram_url, placeholder: "https://instagram.com/..." %>
            </div>
            <div>
              <%= f.label :threads_url, "Threads" %>
              <%= f.url_field :threads_url, placeholder: "https://threads.net/..." %>
            </div>
            <div>
              <%= f.label :bluesky_url, "Bluesky" %>
              <%= f.url_field :bluesky_url, placeholder: "https://bsky.app/profile/..." %>
            </div>
            <div>
              <%= f.label :youtube_url, "YouTube" %>
              <%= f.url_field :youtube_url, placeholder: "https://youtube.com/..." %>
            </div>
          </div>
        </section>

        <div class="member-form-actions">
          <%= f.submit "Save Profile", class: "button" %>
          <%= link_to "View Public Profile", profile_path(@profile), class: "button member-secondary-button" %>
        </div>
      </div>

      <aside class="member-profile-sidebar">
        <section class="panel member-preview-card">
          <h2>Current Profile Preview</h2>
          <p class="form-help">These previews show the images currently visible on your public profile.</p>

          <div class="member-preview-media-block">
            <h3>Profile Picture</h3>
            <% if @profile.avatar_image_source.present? %>
              <%= image_tag @profile.avatar_image_source, alt: "Current profile picture", class: "member-preview-avatar" %>
            <% else %>
              <div class="member-preview-placeholder">No profile image yet</div>
            <% end %>
          </div>

          <div class="member-preview-media-block">
            <h3>Book Covers</h3>
            <% if @profile.books.any? %>
              <div class="member-preview-books-grid">
                <% @profile.books.each do |book| %>
                  <% if book.cover_image_source.present? %>
                    <%= image_tag book.cover_image_source, alt: "#{book.title} cover preview", class: "member-preview-mini-cover" %>
                  <% else %>
                    <div class="member-preview-mini-placeholder">No cover</div>
                  <% end %>
                <% end %>
              </div>
            <% else %>
              <div class="member-preview-placeholder member-preview-placeholder-book">No book cover yet</div>
            <% end %>
          </div>
        </section>
      </aside>
    </div>
  <% end %>
</section>
