<section class="admin-shell">
  <h1>Users</h1>

  <section class="panel">
    <h2>Add Member</h2>
    <p class="form-help">Create a member account by email. A temporary password will be generated automatically.</p>

    <%= form_with model: @new_member, url: admin_users_path, class: "form-stack" do |f| %>
      <% if @new_member.errors.any? %>
        <div class="form-errors">
          <h2>Please fix these issues:</h2>
          <ul>
            <% @new_member.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :email, "Email address" %>
        <%= f.email_field :email, autocomplete: "email", placeholder: "member@example.com" %>
      </div>

      <div>
        <%= f.submit "Add Member", class: "button" %>
      </div>
    <% end %>
  </section>

  <div class="admin-grid">
    <article class="panel">
      <h2>Admins (Pinned First)</h2>
      <ul class="link-list">
        <% @admins.each do |admin| %>
          <li>
            <strong><%= admin.email %></strong>
            <span>Joined <%= admin.created_at.to_date %></span>
          </li>
        <% end %>
      </ul>
    </article>

    <article class="panel">
      <h2>Members</h2>
      <ul class="link-list">
        <% @members.each do |member| %>
          <li>
            <div>
              <%= member.email %>
              <span>Joined <%= member.created_at.to_date %></span>
            </div>
            <%= link_to "Login as user", masquerade_path(member), class: "button", data: { turbo: false } %>
          </li>
        <% end %>
      </ul>
    </article>
  </div>
</section>
