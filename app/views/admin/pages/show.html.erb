<section class="admin-shell">
  <div class="cms-header-row">
    <div>
      <h1><%= @page.title %></h1>
      <p>Slug: /pages/<%= @page.slug %></p>
    </div>
    <div class="cms-show-actions">
      <%= link_to "Preview", preview_admin_page_path(@page), class: "button", target: "_blank", rel: "noopener" %>
      <%= link_to "Edit", edit_admin_page_path(@page), class: "button" %>
      <%= button_to "Delete", admin_page_path(@page), method: :delete, class: "button", form: { data: { turbo_confirm: "Delete this page?" } } %>
    </div>
  </div>

  <article class="panel">
    <p><strong>State:</strong> <%= content_state_badge(@page) %></p>
    <p><strong>Publishing:</strong> <span class="cms-publish-detail"><%= content_publish_detail(@page) %></span></p>
    <p><strong>Layout:</strong> <%= @page.layout_template.titleize %></p>
    <p><strong>Summary:</strong> <%= @page.summary.presence || "No summary added." %></p>
    <% if @page.live_now? %>
      <p><strong>Public URL:</strong> <%= link_to page_path(@page.slug), page_path(@page.slug), class: "text-link", target: "_blank", rel: "noopener" %></p>
    <% end %>
    <% if @page.builder_html.present? %>
      <div class="cms-rich-preview unlayer-rendered-content"><%= sanitize(@page.sanitized_builder_html) %></div>
    <% else %>
      <div class="cms-rich-preview"><%= @page.body %></div>
    <% end %>
  </article>
</section>
