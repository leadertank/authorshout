<section class="admin-shell">
  <h1>Admin Dashboard</h1>

  <div class="stats-grid">
    <article class="panel stat-card">
      <h2>Members</h2>
      <p class="stat"><%= @total_members %></p>
    </article>
    <article class="panel stat-card">
      <h2>Admins</h2>
      <p class="stat"><%= @total_admins %></p>
    </article>
    <article class="panel stat-card">
      <h2>Books</h2>
      <p class="stat"><%= @total_books %></p>
    </article>
    <article class="panel stat-card">
      <h2>Total Likes</h2>
      <p class="stat"><%= @total_likes %></p>
    </article>
    <article class="panel stat-card">
      <h2>Pages</h2>
      <p class="stat"><%= @total_pages %></p>
    </article>
    <article class="panel stat-card">
      <h2>Posts</h2>
      <p class="stat"><%= @total_posts %></p>
    </article>
  </div>

  <div class="stats-grid cms-content-health-grid">
    <article class="panel stat-card">
      <h2>Live Pages</h2>
      <p class="stat"><%= @live_pages %></p>
    </article>
    <article class="panel stat-card">
      <h2>Scheduled Pages</h2>
      <p class="stat"><%= @scheduled_pages %></p>
    </article>
    <article class="panel stat-card">
      <h2>Draft Pages</h2>
      <p class="stat"><%= @draft_pages %></p>
    </article>
    <article class="panel stat-card">
      <h2>Live Posts</h2>
      <p class="stat"><%= @live_posts %></p>
    </article>
    <article class="panel stat-card">
      <h2>Scheduled Posts</h2>
      <p class="stat"><%= @scheduled_posts %></p>
    </article>
    <article class="panel stat-card">
      <h2>Draft Posts</h2>
      <p class="stat"><%= @draft_posts %></p>
    </article>
  </div>

  <div class="cms-quick-links panel">
    <h2>Content Management</h2>
    <div class="cms-quick-actions">
      <%= link_to "Manage Pages", admin_pages_path, class: "button" %>
      <%= link_to "Create Page", new_admin_page_path, class: "button" %>
      <%= link_to "Manage Posts", admin_posts_path, class: "button" %>
      <%= link_to "Write Post", new_admin_post_path, class: "button" %>
    </div>
  </div>

  <div class="admin-grid">
    <article class="panel">
      <h2>Member Signups (14 days)</h2>
      <% max_value = [@member_growth.values.max.to_i, 1].max %>
      <% @member_growth.each do |date, count| %>
        <div class="mini-chart-row">
          <span><%= date %></span>
          <div class="mini-chart-bar-wrap">
            <div class="mini-chart-bar" style="width: <%= (count.to_f / max_value * 100).round %>%"></div>
          </div>
          <span><%= count %></span>
        </div>
      <% end %>
    </article>

    <article class="panel">
      <h2>Books Added (14 days)</h2>
      <% max_books = [@book_growth.values.max.to_i, 1].max %>
      <% @book_growth.each do |date, count| %>
        <div class="mini-chart-row">
          <span><%= date %></span>
          <div class="mini-chart-bar-wrap">
            <div class="mini-chart-bar" style="width: <%= (count.to_f / max_books * 100).round %>%"></div>
          </div>
          <span><%= count %></span>
        </div>
      <% end %>
    </article>

    <article class="panel">
      <h2>Top Liked Books</h2>
      <ul class="link-list">
        <% @top_books.each do |book| %>
          <li>
            <%= link_to book.title, profile_path(book.profile), class: "text-link" %>
            (<%= book.total_likes %> likes)
          </li>
        <% end %>
      </ul>
    </article>

    <article class="panel">
      <h2>Recent Accounts</h2>
      <ul class="link-list">
        <% @recent_members.each do |member| %>
          <li>
            <%= member.email %>
            <% if member.admin? %>
              (admin)
            <% end %>
          </li>
        <% end %>
      </ul>
    </article>

    <article class="panel">
      <h2>Recently Updated Pages</h2>
      <ul class="link-list">
        <% @recent_pages.each do |page| %>
          <li>
            <%= link_to page.title, edit_admin_page_path(page), class: "text-link" %>
            <span class="cms-inline-state"><%= page.content_state_label %></span>
          </li>
        <% end %>
      </ul>
    </article>

    <article class="panel">
      <h2>Recently Updated Posts</h2>
      <ul class="link-list">
        <% @recent_posts.each do |post| %>
          <li>
            <%= link_to post.title, edit_admin_post_path(post), class: "text-link" %>
            <span class="cms-inline-state"><%= post.content_state_label %></span>
          </li>
        <% end %>
      </ul>
    </article>
  </div>
</section>
