<section class="admin-shell">
  <div class="cms-header-row">
    <div>
      <h1><%= @form.title %></h1>
      <p>Slug: /forms/<%= @form.slug %></p>
    </div>
    <div class="cms-show-actions">
      <%= link_to "Submissions", admin_form_submissions_path(@form), class: "button" %>
      <%= link_to "Edit", edit_admin_form_path(@form), class: "button" %>
      <% if @form.published? %>
        <%= link_to "Open", form_path(@form), class: "button", target: "_blank", rel: "noopener" %>
      <% end %>
      <%= button_to "Delete", admin_form_path(@form), method: :delete, class: "button", form: { data: { turbo_confirm: "Delete this form?" } } %>
    </div>
  </div>

  <div class="admin-grid">
    <article class="panel">
      <p><strong>State:</strong> <%= content_state_badge(@form) %></p>
      <p><strong>Payment:</strong> <%= payment_mode_badge(@form) %></p>
      <% if @form.requires_payment? %>
        <p><strong>Amount:</strong> <%= @form.formatted_amount %></p>
        <% if @form.subscription? %>
          <p><strong>Billing:</strong> Every <%= @form.billing_interval %></p>
          <p><strong>Plan ID:</strong> <%= @form.provider_plan_id %></p>
        <% end %>
      <% end %>
      <p><strong>Description:</strong> <%= @form.description.presence || "No description added." %></p>
      <p><strong>Success message:</strong> <%= @form.success_message.presence || "Default success flash." %></p>
    </article>

    <article class="panel">
      <h2>Builder Fields</h2>
      <ul class="link-list">
        <% @form.form_fields.each do |field| %>
          <li>
            <strong><%= field.label %></strong>
            <span><%= field.field_type.humanize %> · <%= field.required? ? "Required" : "Optional" %></span>
          </li>
        <% end %>
      </ul>
    </article>

    <article class="panel">
      <h2>Submission Snapshot</h2>
      <p><strong>Total:</strong> <%= @form.form_submissions.count %></p>
      <p><strong>Completed:</strong> <%= @form.form_submissions.completed.count %></p>
      <p><strong>Pending payment:</strong> <%= @form.form_submissions.payment_pending.count %></p>
      <p><strong>Paid:</strong> <%= @form.form_submissions.paid.count %></p>
    </article>

    <article class="panel">
      <h2>Recent Entries</h2>
      <ul class="link-list">
        <% @recent_submissions.each do |submission| %>
          <li>
            <%= link_to(submission.submitter_email.presence || submission.public_token, admin_form_submission_path(@form, submission), class: "text-link") %>
            <span><%= submission.payment_status.humanize %></span>
          </li>
        <% end %>
      </ul>
    </article>
  </div>
</section>