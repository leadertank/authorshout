<%= form_with model: [:admin, form], class: "cms-form form-builder-form", data: { controller: "form-builder" } do |f| %>
  <% if form.errors.any? %>
    <div class="form-errors">
      <h2>Please fix these issues:</h2>
      <ul>
        <% form.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="cms-grid-two">
    <div>
      <%= f.label :title %>
      <%= f.text_field :title %>
    </div>
    <div>
      <%= f.label :slug %>
      <%= f.text_field :slug, placeholder: "auto-generated-if-left-blank" %>
    </div>
  </div>

  <div class="cms-grid-two">
    <div>
      <%= f.label :status %>
      <%= f.select :status, Form.statuses.keys.map { |status| [status.humanize, status] }, {}, class: "cms-select" %>
    </div>
    <div>
      <%= f.label :submit_button_text %>
      <%= f.text_field :submit_button_text %>
    </div>
  </div>

  <div>
    <%= f.label :description %>
    <%= f.text_area :description, rows: 3 %>
  </div>

  <div>
    <%= f.label :success_message %>
    <%= f.text_area :success_message, rows: 2, placeholder: "Thanks. Your form has been submitted." %>
  </div>

  <section class="panel form-builder-settings-panel">
    <div class="cms-header-row">
      <div>
        <h2>Payment Settings</h2>
        <p class="cms-field-hint">Use free, one-time, or subscription billing. PayPal client credentials are read from environment variables.</p>
      </div>
    </div>

    <div class="cms-grid-three">
      <div>
        <%= f.label :payment_mode %>
        <%= f.select :payment_mode, Form.payment_modes.keys.map { |mode| [mode.humanize, mode] }, {}, class: "cms-select" %>
      </div>
      <div>
        <%= f.label :payment_provider %>
        <%= f.select :payment_provider, [["PayPal", "paypal"]], {}, class: "cms-select" %>
      </div>
      <div>
        <%= f.label :currency %>
        <%= f.text_field :currency, placeholder: "USD" %>
      </div>
    </div>

    <div class="cms-grid-three">
      <div>
        <%= f.label :amount_cents, "Amount (cents)" %>
        <%= f.number_field :amount_cents, min: 0, step: 1 %>
      </div>
      <div>
        <%= f.label :billing_interval %>
        <%= f.select :billing_interval, [["Not recurring", ""], ["Day", "day"], ["Week", "week"], ["Month", "month"], ["Year", "year"]], {}, class: "cms-select" %>
      </div>
      <div>
        <%= f.label :provider_plan_id, "PayPal plan ID" %>
        <%= f.text_field :provider_plan_id, placeholder: "P-123456789" %>
      </div>
    </div>

    <div class="form-builder-paypal-status <%= paypal_config.configured? ? "is-ready" : "is-warning" %>">
      <p><strong>PayPal environment:</strong> <%= paypal_config.environment %></p>
      <% if paypal_config.configured? %>
        <p class="cms-field-hint">Credentials detected. You can test sandbox checkout immediately for one-time forms.</p>
      <% else %>
        <p class="cms-field-hint">Missing credentials: <%= paypal_config.missing_keys.join(", ") %>.</p>
      <% end %>

      <% readiness = form_checkout_readiness(form) %>
      <% if readiness.messages.any? %>
        <ul class="form-builder-warning-list">
          <% readiness.messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      <% end %>
    </div>
  </section>

  <section class="panel form-builder-shell">
    <div class="cms-header-row">
      <div>
        <h2>Fields</h2>
        <p class="cms-field-hint">Drag to reorder. Choice fields read one option per line.</p>
      </div>
      <div class="form-builder-toolbar">
        <% FormField::FIELD_TYPES.each do |field_type| %>
          <button type="button" class="cms-add-block" data-action="click->form-builder#addField" data-form-builder-field-type-param="<%= field_type %>"><%= field_type.humanize %></button>
        <% end %>
      </div>
    </div>

    <div class="form-builder-list" data-form-builder-target="list">
      <%= f.fields_for :form_fields do |field_fields| %>
        <%= render "field_fields", f: field_fields %>
      <% end %>
    </div>

    <template data-form-builder-target="template">
      <%= f.fields_for :form_fields, FormField.new, child_index: "NEW_RECORD" do |field_fields| %>
        <%= render "field_fields", f: field_fields %>
      <% end %>
    </template>
  </section>

  <div class="cms-form-actions">
    <%= f.submit class: "button" %>
  </div>
<% end %>