<section class="admin-shell">
  <div class="cms-header-row">
    <div>
      <h1>Forms</h1>
      <p>Build public forms, collect entries, and attach one-time or subscription payments.</p>
    </div>
    <%= link_to "New Form", new_admin_form_path, class: "button" %>
  </div>

  <%= form_with url: admin_forms_path, method: :get, class: "panel cms-filter-form", local: true do %>
    <div class="cms-grid-two">
      <div>
        <label for="query">Search</label>
        <%= text_field_tag :query, params[:query], placeholder: "Title, slug, description" %>
      </div>
      <div>
        <label for="state">State</label>
        <%= select_tag :state, options_for_select(form_state_filter_options, params[:state]), class: "cms-select" %>
      </div>
    </div>

    <div class="cms-filter-actions">
      <%= submit_tag "Filter", class: "button" %>
      <%= link_to "Clear", admin_forms_path, class: "text-link" %>
    </div>
  <% end %>

  <div class="cms-table-wrap panel">
    <table class="cms-table">
      <thead>
        <tr>
          <th>Form</th>
          <th>State</th>
          <th>Payment</th>
          <th>Fields</th>
          <th>Submissions</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @forms.each do |form| %>
          <tr>
            <td>
              <strong><%= form.title %></strong><br>
              <span class="cms-slug">/forms/<%= form.slug %></span>
            </td>
            <td><%= content_state_badge(form) %></td>
            <td>
              <%= payment_mode_badge(form) %>
              <% if form.requires_payment? %>
                <div class="cms-field-hint"><%= form.formatted_amount %></div>
              <% end %>
            </td>
            <td><%= form.form_fields.size %></td>
            <td><%= form.form_submissions.size %></td>
            <td class="cms-table-actions">
              <%= link_to "View", admin_form_path(form), class: "text-link" %>
              <% if form.published? %>
                <%= link_to "Open", form_path(form), class: "text-link", target: "_blank", rel: "noopener" %>
              <% end %>
              <%= link_to "Edit", edit_admin_form_path(form), class: "text-link" %>
            </td>
          </tr>
        <% end %>

        <% if @forms.empty? %>
          <tr>
            <td colspan="6" class="cms-empty-state">No forms matched this filter.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>