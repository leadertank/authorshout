<section class="admin-shell">
  <div class="cms-header-row">
    <div>
      <h1>Edit Form</h1>
      <p>Update the builder, billing settings, and submission handling for this form.</p>
    </div>
    <div class="cms-show-actions">
      <%= link_to "View", admin_form_path(@form), class: "button" %>
      <% if @form.published? %>
        <%= link_to "Open Public Form", form_path(@form), class: "button", target: "_blank", rel: "noopener" %>
      <% end %>
    </div>
  </div>

  <%= render "form", form: @form %>
</section>