<section class="admin-shell">
  <div class="cms-header-row">
    <div>
      <h1><%= @post.title %></h1>
      <p>Slug: /blog/<%= @post.slug %></p>
    </div>
    <div class="cms-show-actions">
      <%= link_to "Preview", preview_admin_post_path(@post), class: "button", target: "_blank", rel: "noopener" %>
      <%= link_to "Edit", edit_admin_post_path(@post), class: "button" %>
      <%= button_to "Delete", admin_post_path(@post), method: :delete, class: "button", form: { data: { turbo_confirm: "Delete this post?" } } %>
    </div>
  </div>

  <article class="panel">
    <p><strong>State:</strong> <%= content_state_badge(@post) %></p>
    <p><strong>Publishing:</strong> <span class="cms-publish-detail"><%= content_publish_detail(@post) %></span></p>
    <p><strong>Excerpt:</strong> <%= @post.excerpt.presence || "No excerpt added." %></p>
    <% if @post.live_now? %>
      <p><strong>Public URL:</strong> <%= link_to post_path(@post.slug), post_path(@post.slug), class: "text-link", target: "_blank", rel: "noopener" %></p>
    <% end %>
    <div class="cms-rich-preview"><%= @post.body %></div>
  </article>
</section>
