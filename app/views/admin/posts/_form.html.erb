<%= form_with model: [:admin, post], class: "cms-form" do |f| %>
  <% if post.errors.any? %>
    <div class="form-errors">
      <h2>Please fix these issues:</h2>
      <ul>
        <% post.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="cms-grid-two">
    <div>
      <%= f.label :title %>
      <%= f.text_field :title %>
    </div>

    <div>
      <%= f.label :slug %>
      <%= f.text_field :slug, placeholder: "auto-generated-if-left-blank" %>
    </div>
  </div>

  <div class="cms-grid-two">
    <div>
      <%= f.label :status %>
      <%= f.select :status, Post.statuses.keys.map { |status| [status.titleize, status] }, {}, class: "cms-select" %>
    </div>

    <div>
      <%= f.label :published_at, "Publish date" %>
      <%= f.datetime_local_field :published_at %>
    </div>
  </div>

  <div class="cms-grid-two">
    <div>
      <%= f.label :post_category_id, "Category" %>
      <%= f.select :post_category_id, options_from_collection_for_select(@post_categories, :id, :name, post.post_category_id), { include_blank: "No category" }, class: "cms-select" %>
    </div>

    <div>
      <%= f.label :category_name, "Or create a category" %>
      <%= f.text_field :category_name, value: post.category_name, placeholder: "Features" %>
      <p class="cms-field-hint">
        If provided, this overrides the dropdown and creates or reuses a category.
        <%= "Current category: #{post.post_category.name}." if post.post_category.present? %>
      </p>
    </div>
  </div>

  <div>
    <%= f.label :tag_list, "Tags" %>
    <%= f.text_field :tag_list, value: post.tag_list, placeholder: "launch, interview, marketing" %>
    <p class="cms-field-hint">Separate tags with commas. Existing tags are reused automatically.</p>
  </div>

  <div>
    <%= f.label :excerpt %>
    <%= f.text_area :excerpt, rows: 3 %>
  </div>

  <div>
    <%= f.label :featured_image %>
    <%= f.file_field :featured_image, accept: "image/*" %>
  </div>

  <div>
    <%= f.label :body, "Rich text post body" %>
    <%= f.rich_textarea :body %>
  </div>

  <div class="cms-form-actions">
    <%= f.submit class: "button" %>
  </div>
<% end %>
