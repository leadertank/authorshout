<section class="admin-shell">
  <div class="cms-header-row">
    <div>
      <h1>Submission for <%= @form.title %></h1>
      <p>Submitted by <%= @submission.submitter_email.presence || @submission.public_token %></p>
    </div>
    <div class="cms-show-actions">
      <%= link_to "Back to Submissions", admin_form_submissions_path(@form), class: "button" %>
    </div>
  </div>

  <div class="admin-grid">
    <article class="panel">
      <p><strong>Status:</strong> <%= @submission.status.humanize %></p>
      <p><strong>Payment status:</strong> <%= @submission.payment_status.humanize %></p>
      <p><strong>Payment provider:</strong> <%= @submission.payment_provider.presence || "None" %></p>
      <p><strong>Reference:</strong> <%= @submission.payment_reference.presence || "Not recorded" %></p>
      <p><strong>Submitted:</strong> <%= (@submission.submitted_at || @submission.created_at).to_fs(:long) %></p>
    </article>

    <article class="panel">
      <h2>Answers</h2>
      <dl class="submission-answer-list">
        <% @form.form_fields.each do |field| %>
          <% value = @submission.payload[field.identifier] %>
          <dt><%= field.label %></dt>
          <dd><%= value.is_a?(Array) ? value.join(", ") : value.presence || "-" %></dd>
        <% end %>
      </dl>
    </article>
  </div>
</section>