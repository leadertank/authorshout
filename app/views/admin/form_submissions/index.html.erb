<section class="admin-shell">
  <div class="cms-header-row">
    <div>
      <h1><%= @form.title %> Submissions</h1>
      <p>Track entries, payment status, and export form data.</p>
    </div>
    <div class="cms-show-actions">
      <%= link_to "Back to Form", admin_form_path(@form), class: "button" %>
      <%= link_to "Export CSV", export_admin_form_submissions_path(@form, format: :csv), class: "button" %>
    </div>
  </div>

  <div class="cms-table-wrap panel">
    <table class="cms-table">
      <thead>
        <tr>
          <th>Submitted</th>
          <th>Email</th>
          <th>Status</th>
          <th>Payment</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @submissions.each do |submission| %>
          <tr>
            <td><%= (submission.submitted_at || submission.created_at).to_fs(:long) %></td>
            <td><%= submission.submitter_email.presence || "Unknown" %></td>
            <td><%= submission.status.humanize %></td>
            <td><%= submission.payment_status.humanize %></td>
            <td class="cms-table-actions"><%= link_to "View", admin_form_submission_path(@form, submission), class: "text-link" %></td>
          </tr>
        <% end %>

        <% if @submissions.empty? %>
          <tr>
            <td colspan="5" class="cms-empty-state">No submissions yet.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>