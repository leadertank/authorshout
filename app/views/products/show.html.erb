<section class="admin-shell">
  <h1>Products</h1>
  <p class="meta-line">Choose the product that fits your current publishing goal.</p>

  <div class="admin-grid">
    <article class="panel">
      <h2>Social Media Book Blitz</h2>
      <p>Submit your book for social media promotion and increased reader visibility.</p>
      <p>
        <%= link_to "Go to Book Blitz Form", new_social_media_blitz_submission_path, class: "button" %>
      </p>
    </article>

    <article class="panel">
      <h2>Book Awards Submission</h2>
      <p>Enter your book in the AuthorShout awards program and complete checkout.</p>
      <p>
        <%= link_to "Go to Awards Form", new_awards_submission_path, class: "button" %>
      </p>
    </article>
  </div>
</section>
