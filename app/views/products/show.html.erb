<section class="admin-shell">
  <h1>Promotion Packages</h1>
  <p class="meta-line">Choose the promotion package that fits your publishing goal.</p>

  <div class="admin-grid">
    <article class="panel">
      <h2>Social Media Book Blitz</h2>
      <p>Submit your book for social media promotion and increased reader visibility.</p>
      <p>
        <%= link_to "Click to view details", new_social_media_blitz_submission_path, class: "button" %>
      </p>
    </article>

    <article class="panel">
      <h2>Book Awards Submission</h2>
      <p>Enter your book in the Author Shout awards program.</p>
      <p>
        <%= link_to "Click to view details", new_awards_submission_path, class: "button" %>
      </p>
    </article>
  </div>
</section>
