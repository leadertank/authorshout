<section class="panel auth-shell">
  <h1>Book Blitz Request Received</h1>
  <p>Thank you for purchasing the Social Media Book Blitz package.</p>
  <p>Your payment was received and your request details were submitted.</p>

  <ul class="awards-success-list">
    <li><strong>Author:</strong> <%= @awards_submission.submitter_name %></li>
    <li><strong>Email:</strong> <%= @awards_submission.author_email %></li>
    <li><strong>Book:</strong> <%= @awards_submission.book_title %></li>
    <li><strong>Blurb:</strong> <%= @awards_submission.teaser_blurb %></li>
    <li><strong>Paid:</strong> <%= @awards_submission.paid_at.present? ? l(@awards_submission.paid_at, format: :long) : "Yes" %></li>
  </ul>

  <p class="form-help">Need to submit another book? <%= link_to "Start another Social Media Book Blitz order", new_social_media_blitz_submission_path, class: "text-link" %>.</p>
</section>
