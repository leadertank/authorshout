<section class="content-page">
  <article class="panel content-page-hero">
    <h1><%= @form.title %></h1>
    <p class="content-page-summary"><%= @form.success_message.presence || "Thanks. Your form has been submitted successfully." %></p>
    <% if @form.requires_payment? %>
      <p class="cms-field-hint">Payment reference: <%= @submission.payment_reference.presence || "Pending confirmation" %></p>
    <% end %>
    <p><%= link_to "Back to Home", root_path, class: "button" %></p>
  </article>
</section>